# Shared
GOOGLE_CLOUD_PROJECT=your-project-id
GOOGLE_CLOUD_LOCATION=asia-northeast1

# --- Google OAuth (web-chat) ---
# Single source of truth: terraform/terraform.tfvars → terraform apply → ./scripts/run-web-chat.sh
# Do NOT put GOOGLE_OAUTH_CLIENT_* in packages/web-chat/.env.local (run-web-chat.sh passes them via process env).
# Register OAUTH_REDIRECT_URI in Google Cloud Console → Credentials → OAuth client
# Authorized redirect URIs. See: terraform output web_oauth_redirect_uris
OAUTH_REDIRECT_URI=http://localhost:3000/api/auth/callback

# --- Google OAuth (IDE MCP — Cursor) ---
# Required for Cursor: export before starting Cursor (see .cursor/mcp.json).
# Create Desktop app in GCP Console; register terraform output mcp_oauth_redirect_uris.
# Not required for Claude Code URL-only .mcp.json (scopes come from server PRM).
MCP_GOOGLE_OAUTH_CLIENT_ID=
MCP_GOOGLE_OAUTH_CLIENT_SECRET=

# --- Client → agent (local proxy or docker compose) ---
AGENT_URL=http://127.0.0.1:8081

# --- Set by deploy scripts on Cloud Run (not OAuth callbacks) ---
# PUBLIC_AGENT_URL  — remote-agent agent card base URL (deploy-agent.sh)
# MCP_RESOURCE_URL  — bq-mcp protected resource URL (deploy-mcp.sh)
# MCP_SERVER_URL    — auto-detected by deploy-agent.sh from bq-mcp service

# Local web-chat: copy this file to packages/web-chat/.env.local

# Docker Compose overrides (optional .env at repo root)
# AUTH_MODE=dev is set in docker-compose.yml for bq-mcp

# Cloud Run deploy: REMOTE_AGENT_SA_EMAIL and BQ_MCP_SA_EMAIL from terraform output
