{
  "$schema": "https://unpkg.com/knip@6/schema.json",
  "ignoreBinaries": ["grype", "gcloud"],
  "workspaces": {
    ".": {
      "entry": ["stylelint.config.mjs", "scripts/cloud-run-local-proxy.mjs"],
      "project": ["**/*.{js,cjs,mjs,ts,cts,mts}", "!packages/**", "!.trunk/**", "!node_modules/**"]
    },
    "packages/*": {
      "project": ["src/**/*.{ts,tsx}"]
    }
  }
}
